#!/bin/bash
# Git post-commit reminder for a public OSS repository.
#
# discussion-tree is published on GitHub. Commit messages are part of the
# public history. It's easy to slip in business-specific terminology /
# internal project names / customer data while iterating in private,
# then push without re-reading what's about to be world-readable.
#
# This hook fires AFTER each commit and prints a loud reminder so the
# author pauses before `git push`. Install: see scripts/git-hooks/README
# (or symlink this file into .git/hooks/post-commit).

set -e

RED=$'\033[1;31m'
YELLOW=$'\033[1;33m'
RESET=$'\033[0m'

# Write to /dev/tty so the warning is unmissable even when the parent
# git command's stdout/stderr is piped or captured (e.g. inside an IDE
# or another tool driving git). Fall back to stderr if /dev/tty isn't
# available (e.g. CI).
{
  printf '\n%s========================================================================%s\n' "$RED" "$RESET"
  printf '%s⚠  STOP — this is a public repository. Reread the commit message you just wrote BEFORE pushing.%s\n' "$YELLOW" "$RESET"
  printf '%s    Watch for: business / project names, customer terms, internal IDs, credentials, file paths.%s\n' "$YELLOW" "$RESET"
  printf '%s========================================================================%s\n\n' "$RED" "$RESET"
} > /dev/tty 2>/dev/null || {
  printf '\n%s========================================================================%s\n' "$RED" "$RESET" >&2
  printf '%s⚠  STOP — this is a public repository. Reread the commit message you just wrote BEFORE pushing.%s\n' "$YELLOW" "$RESET" >&2
  printf '%s    Watch for: business / project names, customer terms, internal IDs, credentials, file paths.%s\n' "$YELLOW" "$RESET" >&2
  printf '%s========================================================================%s\n\n' "$RED" "$RESET" >&2
}

exit 0
